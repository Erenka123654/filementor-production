# Copy to .dev.vars for local Worker development. Never commit .dev.vars.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-local-password
SESSION_SECRET=replace-with-at-least-32-random-characters
IYZICO_API_KEY=replace-with-iyzico-sandbox-api-key
IYZICO_SECRET_KEY=replace-with-iyzico-sandbox-secret-key
IYZICO_ENVIRONMENT=sandbox
